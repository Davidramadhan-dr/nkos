<nav class="public-navbar">
  <div class="public-navbar-inner">
    <a href="/" class="public-brand"><i class="bi bi-sim-fill"></i> NokosKu</a>

    <div class="public-nav-links d-none d-md-flex">
      <a href="/">Beranda</a>
      <a href="/cari">Cari Nokos</a>
      <% if (currentUser) { %>
        <a href="<%= currentUser.role === 'admin' ? '/admin' : '/dashboard' %>">Dashboard</a>
      <% } %>
    </div>

    <div class="public-nav-actions">
      <% if (currentUser) { %>
        <div class="dropdown">
          <button class="user-menu-btn" data-bs-toggle="dropdown">
            <span class="avatar"><%= currentUser.name.charAt(0).toUpperCase() %></span>
            <span class="d-none d-md-inline"><%= currentUser.name %></span>
            <i class="bi bi-chevron-down small"></i>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="<%= currentUser.role === 'admin' ? '/admin' : '/dashboard' %>"><i class="bi bi-grid-1x2 me-2"></i>Dashboard</a></li>
            <% if (currentUser.role !== 'admin') { %>
              <li><a class="dropdown-item" href="/riwayat"><i class="bi bi-receipt me-2"></i>Riwayat Transaksi</a></li>
              <li><a class="dropdown-item" href="/favorit"><i class="bi bi-heart me-2"></i>Favorit</a></li>
            <% } %>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
          </ul>
        </div>
      <% } else { %>
        <a href="/login" class="btn btn-light btn-sm">Masuk</a>
        <a href="/register" class="btn btn-primary btn-sm">Daftar</a>
      <% } %>
