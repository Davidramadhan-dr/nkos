<!DOCTYPE html>
<html lang="id">
<%- include('../partials/head', { title: title }) %>
<body class="public-body">

  <%- include('../partials/public-navbar') %>

  <section class="section-block">
    <div class="section-inner narrow">
      <h4 class="section-title">Checkout</h4>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="checkout-card">
        <div class="checkout-item">
          <img src="https://picsum.photos/seed/<%= item.image_seed %>/120/90" alt="<%= item.name %>">
          <div>
            <h6><%= item.name %></h6>
            <p class="text-muted small mb-0"><%= item.country %> · <%= item.provider %></p>
            <p class="text-muted small mb-0"><%= item.number_format %></p>
          </div>
        </div>

        <form method="POST" action="/nokos/<%= item.id %>/beli" class="checkout-form">
          <label class="form-label">Jumlah Nomor</label>
          <input type="number" name="quantity" id="qty" value="1" min="1" max="<%= item.stock %>" class="form-control" onchange="updateTotal()">
          <p class="text-muted small mt-1">Stok tersedia: <%= item.stock %></p>

          <div class="checkout-summary">
            <div class="d-flex justify-content-between">
              <span>Harga satuan</span>
              <strong>Rp<%= item.price.toLocaleString('id-ID') %></strong>
            </div>
            <div class="d-flex justify-content-between">
              <span>Total</span>
              <strong id="totalPrice">Rp<%= item.price.toLocaleString('id-ID') %></strong>
            </div>
          </div>

          <button type="submit" class="btn btn-primary w-100 mt-3">Konfirmasi Pembelian</button>
        </form>
      </div>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>

  <script>
    const price = <%= item.price %>;
    function updateTotal() {
      const qty = parseInt(document.getElementById('qty').value, 10) || 1;
      document.getElementById('totalPrice').textContent =
        'Rp' + (price * qty).toLocaleString('id-ID');
    }
  </script>
</body>
</html>
