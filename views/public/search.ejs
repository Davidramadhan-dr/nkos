<!DOCTYPE html>
<html lang="id">
<%- include('../partials/head', { title: title }) %>
<body class="public-body">

  <%- include('../partials/public-navbar') %>

  <section class="section-block">
    <div class="section-inner">
      <h4 class="section-title">Cari Nokos</h4>

      <form action="/cari" method="GET" class="filter-bar">
        <input type="text" name="q" placeholder="Cari nama/provider..." value="<%= filters.q %>">
        <select name="category">
          <option value="">Semua Kategori</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.category %>" <%= filters.category === c.category ? 'selected' : '' %>><%= c.category %></option>
          <% }) %>
        </select>
        <select name="country">
          <option value="">Semua Negara</option>
          <% countries.forEach(c => { %>
            <option value="<%= c.country %>" <%= filters.country === c.country ? 'selected' : '' %>><%= c.country %></option>
          <% }) %>
        </select>
        <select name="sort">
          <option value="">Urutkan</option>
          <option value="harga_asc" <%= filters.sort === 'harga_asc' ? 'selected' : '' %>>Harga Terendah</option>
          <option value="harga_desc" <%= filters.sort === 'harga_desc' ? 'selected' : '' %>>Harga Tertinggi</option>
          <option value="rating" <%= filters.sort === 'rating' ? 'selected' : '' %>>Rating Tertinggi</option>
        </select>
        <button type="submit" class="btn btn-primary">Terapkan</button>
      </form>

      <p class="text-muted small mb-3"><%= results.length %> nomor virtual ditemukan</p>

      <div class="nokos-grid">
        <% results.forEach(item => { %>
          <%- include('../partials/nokos-card', { item }) %>
        <% }) %>
        <% if (results.length === 0) { %>
          <p class="text-muted">Tidak ada nokos yang cocok dengan filter kamu. Coba ubah pencarian.</p>
        <% } %>
      </div>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>
