<%- include('../partials/user-header') %>

<div class="app-main">
  <%- include('../partials/user-topbar') %>
  
  <div class="app-content">
    <div class="page-header">
      <div>
        <h4>Topup Saldo</h4>
        <p style="color: var(--text-muted); margin: 0; font-size: 0.85rem;">Tambah saldo untuk membeli nokos</p>
      </div>
      <div style="font-size: 1.4rem; font-weight: 800; color: var(--primary);">Rp <%= (user.balance || 0).toLocaleString('id-ID') %></div>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger" role="alert" style="margin-bottom: 1.5rem;">
        <%= error %>
      </div>
    <% } %>

    <div class="panel">
      <h6 style="margin-bottom: 1.5rem;">Pilih Nominal Topup</h6>
      
      <form method="POST" action="/topup/request">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
          <% topupOptions.forEach(option => { %>
            <label style="cursor: pointer; margin: 0;">
              <input type="radio" name="amount" value="<%= option %>" style="display: none;" class="topup-option">
              <div class="topup-choice" style="border: 2px solid var(--border); padding: 1rem; border-radius: .8rem; text-align: center; transition: all .2s;">
                <strong style="display: block; font-size: 1rem; color: var(--primary);">Rp <%= option.toLocaleString('id-ID') %></strong>
                <small style="color: var(--text-muted);">Pilih</small>
              </div>
            </label>
          <% }); %>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <label style="display: block; margin-bottom: .5rem; font-weight: 700; font-size: .9rem;">Atau Masukkan Jumlah Custom</label>
          <input type="number" name="custom_amount" placeholder="Minimal Rp 10.000, Maksimal Rp 5.000.000" 
                 min="10000" max="5000000" step="1000" class="form-control" style="font-size: .9rem;">
          <small style="color: var(--text-muted); display: block; margin-top: .3rem;">Kosongkan jika ingin gunakan nominal di atas</small>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: .7rem;">Lanjut ke Pembayaran</button>
      </form>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.topup-choice').forEach(choice => {
    choice.addEventListener('click', function() {
      document.querySelectorAll('.topup-choice').forEach(c => {
        c.style.borderColor = 'var(--border)';
        c.style.backgroundColor = '#fff';
      });
      this.style.borderColor = 'var(--primary)';
      this.style.backgroundColor = 'rgba(91, 108, 255, 0.05)';
    });
  });
</script>

<%- include('../partials/user-footer') %>