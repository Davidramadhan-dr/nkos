<%- include('../partials/user-header') %>

<div class="app-main">
  <%- include('../partials/user-topbar') %>
  
  <div class="app-content">
    <div class="page-header">
      <h4>Notifikasi</h4>
    </div>

    <% if (notifications && notifications.length > 0) { %>
      <div class="panel">
        <% notifications.forEach(notif => { %>
          <div style="padding: 1rem; border-bottom: 1px solid var(--border); cursor: pointer;" class="notification-item" data-id="<%= notif.id %>" onclick="markAsRead(<%= notif.id %>)">
            <div style="display: flex; justify-content: space-between; align-items: start;">
              <div style="flex: 1;">
                <strong style="display: block; margin-bottom: .2rem;"><%= notif.title %></strong>
                <p style="margin: 0; color: var(--text-muted); font-size: .9rem;"><%= notif.message %></p>
                <small style="color: var(--text-muted); display: block; margin-top: .3rem;">
                  <%= new Date(notif.created_at).toLocaleDateString('id-ID') %>
                </small>
              </div>
              <% if (!notif.is_read) { %>
                <span style="width: 10px; height: 10px; background: var(--primary); border-radius: 50%; margin-left: 1rem; margin-top: .3rem;"></span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="panel" style="text-align: center; padding: 2rem;">
        <i class="fas fa-bell" style="font-size: 2rem; color: var(--text-muted); margin-bottom: .5rem; display: block;"></i>
        <p style="color: var(--text-muted);">Tidak ada notifikasi</p>
      </div>
    <% } %>
  </div>
</div>

<script>
  function markAsRead(id) {
    fetch(`/notifikasi/${id}/baca`, { method: 'POST' });
  }
</script>

<%- include('../partials/user-footer') %>