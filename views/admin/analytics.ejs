<%- include('../partials/admin-header') %>

<div class="app-main">
  <%- include('../partials/admin-topbar') %>
  
  <div class="app-content">
    <div class="page-header">
      <h4>Analytics & Laporan</h4>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(91, 108, 255, 0.15); color: var(--primary);"><i class="fas fa-dollar-sign"></i></div>
        <div>
          <h5>Rp <%= (stats.totalRevenue || 0).toLocaleString('id-ID') %></h5>
          <p>Total Revenue</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(23, 198, 102, 0.15); color: var(--success);"><i class="fas fa-shopping-bag"></i></div>
        <div>
          <h5><%= stats.totalOrders %></h5>
          <p>Total Orders</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(255, 182, 72, 0.15); color: var(--warning);"><i class="fas fa-users"></i></div>
        <div>
          <h5><%= stats.totalUsers %></h5>
          <p>Total Users</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(255, 92, 92, 0.15); color: var(--danger);"><i class="fas fa-wallet"></i></div>
        <div>
          <h5>Rp <%= (stats.approvedTopup || 0).toLocaleString('id-ID') %></h5>
          <p>Topup Approved</p>
        </div>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
      <div class="panel">
        <h6 style="margin-bottom: 1rem;">Penjualan Harian (30 hari terakhir)</h6>
        <% if (dailySalesData && dailySalesData.length > 0) { %>
          <div style="overflow-x: auto;">
            <table class="table" style="margin: 0; font-size: .85rem;">
              <thead>
                <tr>
                  <th>Tanggal</th>
                  <th>Total</th>
                  <th>Jumlah Order</th>
                </tr>
              </thead>
              <tbody>
                <% dailySalesData.forEach(data => { %>
                  <tr>
                    <td><%= new Date(data.date).toLocaleDateString('id-ID') %></td>
                    <td><strong>Rp <%= (data.total || 0).toLocaleString('id-ID') %></strong></td>
                    <td><%= data.count %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--text-muted);">Tidak ada data</p>
        <% } %>
      </div>

      <div class="panel">
        <h6 style="margin-bottom: 1rem;">Kategori Terlaris</h6>
        <% if (categoryStats && categoryStats.length > 0) { %>
          <% categoryStats.forEach(cat => { %>
            <div style="margin-bottom: 1rem;">
              <div style="display: flex; justify-content: space-between; margin-bottom: .3rem;">
                <small><strong><%= cat.category %></strong></small>
                <small style="color: var(--text-muted);"><%= cat.total_sold %> item</small>
              </div>
              <div style="background: var(--bg); height: 6px; border-radius: 3px; overflow: hidden;">
                <div style="background: var(--primary); height: 100%; width: <%= (cat.revenue / categoryStats[0].revenue * 100) %>%;"></div>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>