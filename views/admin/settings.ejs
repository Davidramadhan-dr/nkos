<%- include('../partials/admin-header') %>

<div class="app-main">
  <%- include('../partials/admin-topbar') %>
  
  <div class="app-content">
    <div class="page-header">
      <h4>Pengaturan Sistem</h4>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
      <div class="panel">
        <h6 style="margin-bottom: 1.5rem;">Pengaturan Umum</h6>
        <form>
          <div style="margin-bottom: 1.2rem;">
            <label style="display: block; margin-bottom: .4rem; font-weight: 700; font-size: .9rem;">Nama Toko</label>
            <input type="text" value="NokosKu" class="form-control" disabled>
          </div>
          <div style="margin-bottom: 1.2rem;">
            <label style="display: block; margin-bottom: .4rem; font-weight: 700; font-size: .9rem;">Email Support</label>
            <input type="email" value="support@nokosku.id" class="form-control" disabled>
          </div>
          <button type="button" class="btn btn-primary" onclick="alert('Pengaturan default tidak dapat diubah')">Simpan</button>
        </form>
      </div>

      <div class="panel">
        <h6 style="margin-bottom: 1.5rem;">Pengaturan Topup</h6>
        <div style="margin-bottom: 1.2rem;">
          <label style="display: block; margin-bottom: .4rem; font-weight: 700; font-size: .9rem;">Min Topup</label>
          <input type="number" value="10000" class="form-control" disabled>
        </div>
        <div style="margin-bottom: 1.2rem;">
          <label style="display: block; margin-bottom: .4rem; font-weight: 700; font-size: .9rem;">Max Topup</label>
          <input type="number" value="5000000" class="form-control" disabled>
        </div>
        <button type="button" class="btn btn-primary" onclick="alert('Pengaturan default tidak dapat diubah')">Simpan</button>
      </div>

      <div class="panel">
        <h6 style="margin-bottom: 1.5rem;">Informasi Sistem</h6>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li style="padding: .5rem 0; border-bottom: 1px solid var(--border);">
            <small style="color: var(--text-muted);">Versi</small>
            <div style="font-weight: 700;">1.0.0</div>
          </li>
          <li style="padding: .5rem 0;">
            <small style="color: var(--text-muted);">Database</small>
            <div style="font-weight: 700;">SQLite</div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>